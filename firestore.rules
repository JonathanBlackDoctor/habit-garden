rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner() {
      return request.auth != null
        && request.auth.uid == 'XMgQWlM1wtM62hIheTH4sKGDNuC2';
    }
    function isApproved(uid) {
      return request.auth != null
        && request.auth.uid == uid
        && get(/databases/$(database)/documents/userProfiles/$(uid)).data.status == 'approved';
    }

    match /userProfiles/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isOwner());
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.status == 'pending'
        && request.resource.data.isOwner == false;
      allow update, delete: if isOwner();
    }

    // 본인 데이터는 인증된 사용자(익명 게스트 포함) 누구나 RW.
    // AI·서버 프리미엄 기능은 callable 함수에서 status=='approved' 로 별도 게이트한다.
    match /users/{uid}/{document=**} {
      allow read, write: if (request.auth != null && request.auth.uid == uid) || isOwner();
    }
  }
}
