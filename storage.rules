rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isOwner() {
      return request.auth != null
        && request.auth.uid == 'XMgQWlM1wtM62hIheTH4sKGDNuC2';
    }
    function isApproved(uid) {
      return request.auth != null
        && request.auth.uid == uid
        && firestore.get(/databases/(default)/documents/userProfiles/$(uid)).data.status == 'approved';
    }

    match /users/{uid}/{allPaths=**} {
      allow read, write: if isApproved(uid) || isOwner();
    }
  }
}
